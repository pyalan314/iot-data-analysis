# Grok API Configuration
# Get your API key from: https://console.x.ai/
XAI_API_KEY=your-grok-api-key-here

# Grok model name (options: grok-beta, grok-4-1-fast, etc.)
GROK_MODEL=grok-4-1-fast

# Timezone for data analysis (default: Asia/Hong_Kong for UTC+8)
# Other examples: Asia/Shanghai, Asia/Singapore, America/New_York, Europe/London
TIMEZONE=Asia/Hong_Kong

# Optional: OpenAI API key (if using anomaly_interpreter_llm.py)
# OPENAI_API_KEY=your-openai-api-key-here
