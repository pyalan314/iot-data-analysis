# Environment Variables Configuration
# Copy this file to .env and fill in your actual API keys

# =============================================================================
# Grok API (xAI) - For LLM Narrative Generation
# =============================================================================
# Get your API key from: https://console.x.ai/
# Used by: 4_generate_narrative.py
XAI_API_KEY=your-grok-api-key-here

# Model to use for narrative generation
# Options: grok-beta, grok-2-1212, grok-2-latest
# Default: grok-beta
GROK_MODEL=grok-beta

# LLM generation parameters
# Temperature: 0.0 (deterministic) to 1.0 (creative)
# Default: 0.7
GROK_TEMPERATURE=0.7

# Maximum tokens for response
# Default: 2000
GROK_MAX_TOKENS=2000

# =============================================================================
# Hugging Face Token - For TimesFM Model Access
# =============================================================================
# Get your token from: https://huggingface.co/settings/tokens
# Used by: 2_forecast_anomaly_detection.py
# Note: Optional, but recommended for higher rate limits and faster downloads
HF_TOKEN=your-huggingface-token-here

# =============================================================================
# Usage Instructions
# =============================================================================
# 
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env and replace the placeholder values with your actual API keys
#
# 3. Load environment variables:
#    
#    PowerShell:
#      Get-Content .env | ForEach-Object {
#        if ($_ -match '^([^#][^=]+)=(.+)$') {
#          [System.Environment]::SetEnvironmentVariable($matches[1], $matches[2], 'Process')
#        }
#      }
#
#    Or manually set each variable:
#      $env:XAI_API_KEY='your-actual-key'
#      $env:HF_TOKEN='your-actual-token'
#
#    Linux/Mac (bash):
#      export $(cat .env | grep -v '^#' | xargs)
#
#    Or use python-dotenv:
#      pip install python-dotenv
#      # Add to your script: from dotenv import load_dotenv; load_dotenv()
#
# =============================================================================
# Security Notes
# =============================================================================
# - NEVER commit .env file to version control
# - .env is already in .gitignore
# - Keep your API keys secure and private
# - Rotate keys if accidentally exposed
